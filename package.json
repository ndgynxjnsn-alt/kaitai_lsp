{
	"name": "kaitai-struct-lsp",
	"displayName": "Kaitai Struct",
	"description": "Kaitai Struct for VSCode",
	"icon": "assets/kaitai_16x_dark.png",
	"version": "1.0.1",
	"publisher": "daniellugo",
	"license": "MIT",
	"repository": {
		"type": "GitHub",
		"url": "https://github.com/ndgynxjnsn-alt/kaitai_lsp"
	},
	"engines": {
		"vscode": "^1.75.0"
	},
	"categories": [
		"Programming Languages"
	],
	"main": "./client/out/extension.js",
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "kaitai",
					"title": "Kaitai Struct",
					"icon": "assets/kaitai_16x_dark.svg"
				}
			]
		},
		"views": {
			"kaitai": [
				{ "id": "kaitai.ksyFiles", "name": "KSY Files" },
				{ "id": "kaitai.binaryFiles", "name": "Binary Files" },
				{ "id": "kaitai.converter", "name": "Converter", "type": "webview" }
			]
		},
		"commands": [
			{
				"command": "kaitai-struct.openViewer",
				"title": "Kaitai: Open Hex Viewer",
				"icon": "$(symbol-file)"
			},
			{
				"command": "kaitai-struct.selectBinaryFile",
				"title": "Kaitai: Select Binary File"
			},
			{
				"command": "kaitai-struct.refreshKsy",
				"title": "Kaitai: Refresh KSY Files",
				"icon": "$(refresh)"
			},
			{
				"command": "kaitai-struct.setBinaryGlob",
				"title": "Kaitai: Set Binary Glob",
				"icon": "$(filter)"
			},
			{
				"command": "kaitai-struct.selectBinaryPath",
				"title": "Kaitai: Select Binary Path"
			},
			{
				"command": "kaitai-struct.pasteHex",
				"title": "Kaitai: Paste Hex String",
				"icon": "$(clippy)"
			}
		],
		"menus": {
			"editor/title": [
				{
					"command": "kaitai-struct.openViewer",
					"when": "resourceExtname == .ksy",
					"group": "navigation"
				}
			],
			"view/title": [
				{
					"command": "kaitai-struct.refreshKsy",
					"when": "view == kaitai.ksyFiles",
					"group": "navigation"
				},
				{
					"command": "kaitai-struct.setBinaryGlob",
					"when": "view == kaitai.binaryFiles",
					"group": "navigation"
				}
			]
		},
		"languages": [
			{
				"id": "kaitai-struct",
				"aliases": [
					"Kaitai Struct",
					"ksy"
				],
				"extensions": [
					".ksy"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "kaitai-struct",
				"scopeName": "source.kaitai-struct",
				"path": "./syntaxes/kaitai-struct.tmLanguage.json"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "node esbuild.js",
		"compile": "tsc -b",
		"watch": "tsc -b -w",
		"postinstall": "cd client && npm install && cd ../server && npm install"
	},
	"devDependencies": {
		"@types/node": "^20.11.0",
		"esbuild": "^0.27.4",
		"typescript": "^5.3.0"
	}
}
