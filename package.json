{
	"name": "kaitai-struct-lsp",
	"displayName": "Kaitai Struct",
	"description": "Kaitai Struct for VSCode",
	"version": "0.2.0",
	"publisher": "daniellugo",
	"license": "MIT",
	"repository": {
		"type": "GitHub",
		"url": "https://github.com/ndgynxjnsn-alt/kaitai_lsp"
	},
	"engines": {
		"vscode": "^1.75.0"
	},
	"categories": [
		"Programming Languages"
	],
"main": "./client/out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "kaitai-struct.openViewer",
				"title": "Kaitai: Open Hex Viewer",
				"icon": "$(symbol-file)"
			},
			{
				"command": "kaitai-struct.selectBinaryFile",
				"title": "Kaitai: Select Binary File"
			}
		],
		"menus": {
			"editor/title": [
				{
					"command": "kaitai-struct.openViewer",
					"when": "resourceExtname == .ksy",
					"group": "navigation"
				}
			]
		},
		"languages": [
			{
				"id": "kaitai-struct",
				"aliases": [
					"Kaitai Struct",
					"ksy"
				],
				"extensions": [
					".ksy"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "kaitai-struct",
				"scopeName": "source.kaitai-struct",
				"path": "./syntaxes/kaitai-struct.tmLanguage.json"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "node esbuild.js",
		"compile": "tsc -b",
		"watch": "tsc -b -w",
		"postinstall": "cd client && npm install && cd ../server && npm install"
	},
	"devDependencies": {
		"@types/node": "^20.11.0",
		"esbuild": "^0.27.4",
		"typescript": "^5.3.0"
	}
}
